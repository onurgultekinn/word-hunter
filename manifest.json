{
  "manifest_version": 3,
  "name": "Kelime Avcısı",
  "version": "1.2",
  "description": "Seçilen İngilizce kelimeleri çevirisiyle birlikte kaydeder ve listeler.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}